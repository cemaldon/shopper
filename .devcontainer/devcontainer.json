{
  "name": "Python AI-ML Grocery Prototype",
  
  // Pulls a secure, pre-configured Debian/Ubuntu-based Python image
  "image": "mcr.microsoft.com/devcontainers/python:3.11",

  // Automatically installs your ML packages into the container layer upon creation
  "postCreateCommand": "pip3 install --no-cache-dir -r requirements.txt",

  "customizations": {
    "vscode": {
      // Configures the container's internal editor settings
      "settings": {
        "python.defaultInterpreterPath": "/usr/local/bin/python",
        "python.analysis.typeCheckingMode": "basic"
      },
      // Pre-installs key extensions so the workspace is immediately smart
      "extensions": [
        "ms-python.python",        // Intellisense, linting, and code navigation
        "ms-python.vscode-pylance", // Robust type-checking engine
        "ms-toolsai.jupyter"        // Essential if you prototype models via notebooks
      ]
    }
  },

  // Ensures you aren't running commands blindly as root inside the ecosystem
  "remoteUser": "vscode"
}
